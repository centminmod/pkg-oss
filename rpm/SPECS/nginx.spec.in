#
# Crypto library selection (set by Makefile CRYPTO variable)
%define crypto_lib %%CRYPTO_NAME%%
# Compression library selection (set by Makefile ZLIB variable)
%define zlib_lib %%ZLIB_NAME%%
# Optimization feature toggles (set by Makefile LTO/MARCH/LINKER variables)
%define opt_lto %%LTO%%
%define opt_march %%MARCH%%
%define opt_linker %%LINKER%%
%define opt_autofdo %%AUTOFDO%%

# Centmin Mod path macros — NEVER redefine global RPM macros (%{_libdir} etc.)
%global cm_prefix       /usr/local/nginx
%global cm_sbindir      /usr/local/sbin
%global cm_confdir      %{cm_prefix}/conf
%global cm_logdir       %{cm_prefix}/logs
%global cm_moduledir    %{cm_prefix}/modules
%global cm_htmldir      %{cm_prefix}/html
%global cm_cachedir     /var/cache/nginx

%define nginx_home %{cm_cachedir}
%define nginx_user nginx
%define nginx_group nginx
%define nginx_loggroup adm

BuildRequires: systemd
Requires(post): systemd
Requires(preun): systemd
Requires(postun): systemd

%if 0%{?rhel}
%define _group System Environment/Daemons
%endif

%if (0%{?rhel} == 7) && (0%{?amzn} == 0)
%define epoch 1
Epoch: %{epoch}
Requires(pre): shadow-utils
Requires: openssl >= 1.0.2
Requires: procps-ng
BuildRequires: openssl-devel >= 1.0.2
%define dist .el7
%endif

%if (0%{?rhel} == 7) && (0%{?amzn} == 2)
%define epoch 1
Epoch: %{epoch}
Requires(pre): shadow-utils
Requires: openssl11 >= 1.1.1
Requires: procps-ng
BuildRequires: openssl11-devel >= 1.1.1
%endif

%if 0%{?rhel} == 8
%define epoch 1
Epoch: %{epoch}
Requires(pre): shadow-utils
Requires: procps-ng
BuildRequires: openssl-devel >= 1.1.1
BuildRequires: gcc-toolset-14-gcc gcc-toolset-14-gcc-c++
%define _debugsource_template %{nil}
%endif

%if 0%{?rhel} == 9
%define epoch 2
Epoch: %{epoch}
Requires(pre): shadow-utils
Requires: procps-ng
BuildRequires: openssl-devel
BuildRequires: gcc-toolset-15-gcc gcc-toolset-15-gcc-c++
%define _debugsource_template %{nil}
%endif

%if 0%{?rhel} == 10
%define epoch 2
Epoch: %{epoch}
Requires(pre): shadow-utils
Requires: procps-ng
BuildRequires: openssl-devel
BuildRequires: gcc-toolset-15-gcc gcc-toolset-15-gcc-c++
%define _debugsource_template %{nil}
%endif

%if "%{opt_linker}" == "mold"
BuildRequires: mold
%endif

# end of distribution specific definitions

%define base_version %%BASE_VERSION%%
%define base_release %%BASE_RELEASE%%%{?dist}.cmm

%define bdir %{_builddir}/nginx-%{base_version}

# Centmin Mod compiler flags — %{optflags} intentionally NOT used because
# it reflects system GCC defaults, not the gcc-toolset compiler.
# Dropping %{optflags} loses Red Hat's -specs= annotations but gains explicit
# control matching CM's build configuration.
%if 0%{?rhel} >= 10
%define WITH_CC_OPT -O3 -g -fPIC -fstack-protector-strong -fstack-clash-protection -Wimplicit-fallthrough=0 -Wformat -Wformat-security -Wp,-U_FORTIFY_SOURCE,-D_FORTIFY_SOURCE=3 --param=ssp-buffer-size=4 $(pcre2-config --cflags)
%else
%define WITH_CC_OPT -O3 -g -fPIC -fstack-protector-strong -fstack-clash-protection -Wimplicit-fallthrough=0 -Wformat -Wformat-security -Wp,-D_FORTIFY_SOURCE=2 --param=ssp-buffer-size=4 $(pcre2-config --cflags)
%endif
%if 0%{?rhel} >= 10
%define WITH_LD_OPT -Wl,-z,relro -Wl,-z,now -Wl,--as-needed -Wl,-Bsymbolic-functions
%else
%define WITH_LD_OPT -Wl,-z,relro -Wl,-z,now -pie -Wl,--as-needed -Wl,-Bsymbolic-functions
%endif

# LTO support — -flto=auto on both compile and link lines (GCC requirement)
%if "%{opt_lto}" == "y"
%define LTO_CC_OPT -flto=auto
%define LTO_LD_OPT -flto=auto
%else
%define LTO_CC_OPT %{nil}
%define LTO_LD_OPT %{nil}
%endif

# Microarchitecture targeting — compile-time only
%if "%{opt_march}" == "x86-64-v2"
%define MARCH_CC_OPT -march=x86-64-v2
%endif
%if "%{opt_march}" == "x86-64-v3"
%define MARCH_CC_OPT -march=x86-64-v3
%endif
%if "%{opt_march}" == "x86-64-v4"
%define MARCH_CC_OPT -march=x86-64-v4
%endif
%if "%{opt_march}" == "generic"
%define MARCH_CC_OPT %{nil}
%endif

# Mold linker — link-time only
%if "%{opt_linker}" == "mold"
%define LINKER_LD_OPT -fuse-ld=mold
%else
%define LINKER_LD_OPT %{nil}
%endif

# AutoFDO — compile-time profile-guided optimization
# -fauto-profile goes in --with-cc-opt ONLY (compile-time flag, not linker)
%if "%{opt_autofdo}" != "none" && "%{opt_autofdo}" != ""
# -Wno-error=array-bounds: AutoFDO profile-guided inlining can trigger
# false-positive bounds warnings with -Werror (GCC bug with aggressive optimization)
%define AUTOFDO_CC_OPT -fauto-profile=%{opt_autofdo} -Wno-error=array-bounds
%else
%define AUTOFDO_CC_OPT %{nil}
%endif

%define BASE_CONFIGURE_ARGS $(echo "%%BASE_CONFIGURE_ARGS%%")

Summary: High performance web server (Centmin Mod)
Name: centminmod-nginx%%CRYPTO_PACKAGE_SUFFIX%%
Version: %{base_version}
Release: %{base_release}
Vendor: %%PACKAGE_VENDOR%%
URL: https://centminmod.com/
Group: %{_group}

Source0: https://nginx.org/download/nginx-%{base_version}.tar.gz
Source1: logrotate
Source2: nginx.conf
Source3: nginx.default.conf
Source4: nginx.service
Source5: nginx.upgrade.sh
Source6: nginx.suse.logrotate
Source7: nginx-debug.service
Source8: nginx.copyright
Source9: nginx.check-reload.sh
Source10: dynamic-modules.conf
Source11: dynamic-modules-includes.conf
Source12: maintenance.conf
Source13: sitestatus.conf
Source14: webp.conf
Source15: ssl_include.conf
Source16: fastcgi_param_https_map.conf
Source17: normalize_encoding.conf
Source18: default_phpupstream.conf
Source19: vts_http.conf
Source20: vts_server.conf
Source21: vts_mainserver.conf
Source22: geoip.conf
Source23: pagespeedadmin.conf
Source24: drop.conf
Source25: staticfiles.conf
Source26: php.conf
Source27: errorpage.conf
Source28: phpstatus.conf

%%BASE_PATCHES%%
%%CRYPTO_SOURCES%%
%%CRYPTO_PATCHES%%
%%ZLIB_SOURCES%%

License: 2-clause BSD-like license

BuildRoot: %{_tmppath}/%{name}-%{base_version}-%{base_release}-root
BuildRequires: zlib-devel
BuildRequires: pcre2-devel

%if "%{crypto_lib}" == "awslc"
%if 0%{?rhel} == 8
BuildRequires: cmake3
%else
BuildRequires: cmake
%endif
BuildRequires: ninja-build
BuildRequires: golang
%endif

Provides: webserver
Provides: nginx = %{base_version}-%{base_release}
Provides: nginx-r%{base_version}
Provides: centminmod-nginx%%CRYPTO_PACKAGE_SUFFIX%%-r%{base_version}
Provides: centminmod-nginx-r%{base_version}
Provides: centminmod-nginx-crypto(%%CRYPTO_NAME%%)
Provides: centminmod-nginx-zlib(%%ZLIB_NAME%%)
Conflicts: nginx
Requires: nginx-module-headers-more

%if !(0%{?rhel} == 7)
Recommends: logrotate
%endif

%description
nginx [engine x] is an HTTP and reverse proxy server, as well as
a mail proxy server.

%prep
%setup -q -n nginx-%{base_version}
%%BASE_PREP_PATCHES%%

%if "%{crypto_lib}" == "awslc"
# Extract AWS-LC source
tar xzf %{SOURCE50}
# Note: nginx 1.29.7 has native AWS-LC support — no patches needed
%endif

%if "%{crypto_lib}" == "openssl"
# Extract to parent dir — --with-openssl=../openssl-X.Y.Z is relative to nginx source
tar -C %{_builddir} -xzf %{SOURCE51}
%endif

%if "%{zlib_lib}" == "cloudflare"
# Extract to parent dir, rename to friendly version (shows in nginx -V),
# and pre-run configure so "make distclean" target exists.
# nginx's auto/lib/zlib/make runs "make distclean && ./configure && make libz.a"
# but fresh CF zlib source has no Makefile yet, causing distclean to fail.
tar -C %{_builddir} -xzf %{SOURCE60}
mv %{_builddir}/zlib-%%CF_ZLIB_COMMIT%% %{_builddir}/zlib-cloudflare-%%CF_ZLIB_VERSION%%
cd %{_builddir}/zlib-cloudflare-%%CF_ZLIB_VERSION%%
./configure
cd %{bdir}
%endif

%build
# Activate GCC toolset for enhanced compiler optimizations
%if 0%{?rhel} == 8
. /opt/rh/gcc-toolset-14/enable
%endif
%if 0%{?rhel} == 9
. /opt/rh/gcc-toolset-15/enable
%endif
%if 0%{?rhel} == 10
. /usr/lib/gcc-toolset/15-env.source
%endif
echo "GCC version: $(gcc --version | head -1)"

%if "%{crypto_lib}" == "awslc"
# Build AWS-LC into nginx-dep directory (static linking).
# Using -isystem ensures AWS-LC headers take priority over system
# openssl-devel, similar to Centmin Mod's /usr/local/nginx-dep/ approach.
# Unset rpmbuild CFLAGS — AWS-LC manages its own flags via cmake,
# and jitterentropy requires -O0 which conflicts with FORTIFY_SOURCE.
unset CFLAGS CXXFLAGS LDFLAGS
cd %{bdir}
mkdir -p awslc-build && cd awslc-build
%if 0%{?rhel} == 8
cmake3 \
%else
cmake \
%endif
  -GNinja \
  -DCMAKE_BUILD_TYPE=Release \
  -DCMAKE_POSITION_INDEPENDENT_CODE=TRUE \
  -DBUILD_SHARED_LIBS=OFF \
  -DBUILD_TESTING=OFF \
  -DCMAKE_INSTALL_PREFIX=%{bdir}/nginx-dep \
  ../aws-lc-%%AWSLC_VERSION%%
ninja-build -j$(nproc)
ninja-build install
cd %{bdir}
echo "AWS-LC built and installed to %{bdir}/nginx-dep"
%endif

%if "%{crypto_lib}" == "awslc"
%define CRYPTO_CC_OPT -isystem %{bdir}/nginx-dep/include
%define CRYPTO_LD_OPT -L%{bdir}/nginx-dep/lib64 -lssl -lcrypto -lpthread -ldl
%define CRYPTO_CONFIGURE_ARGS %{nil}
%define CRYPTO_POST_CONFIGURE %{nil}
%endif
%if "%{crypto_lib}" == "openssl"
%define CRYPTO_CC_OPT %{nil}
# -Wl,-E exports all dynamic symbols so modules can resolve them at load time
%define CRYPTO_LD_OPT -Wl,-E
%define CRYPTO_CONFIGURE_ARGS --with-openssl=../openssl-%%OPENSSL_CUSTOM_VERSION%% --with-openssl-opt='enable-ec_nistp_64_gcc_128 enable-tls1_3'
# Post-configure: patch objs/Makefile to use --whole-archive for OpenSSL static libs
# so that all symbols (including MD5) are included in the binary for dynamic module use
%define CRYPTO_POST_CONFIGURE sed -i 's|-lssl -lcrypto|-Wl,--whole-archive -lssl -lcrypto -Wl,--no-whole-archive|g' objs/Makefile
%endif
%if "%{crypto_lib}" == "system"
%define CRYPTO_CC_OPT %{nil}
%define CRYPTO_LD_OPT %{nil}
%define CRYPTO_CONFIGURE_ARGS %{nil}
%define CRYPTO_POST_CONFIGURE %{nil}
%endif

%if "%{zlib_lib}" == "cloudflare"
%define ZLIB_CONFIGURE_ARGS %%ZLIB_CONFIGURE_ARGS%%
%else
%define ZLIB_CONFIGURE_ARGS %{nil}
%endif

./configure %{BASE_CONFIGURE_ARGS} %{ZLIB_CONFIGURE_ARGS} %{CRYPTO_CONFIGURE_ARGS} \
    --with-cc-opt="%{WITH_CC_OPT} %{CRYPTO_CC_OPT} %{LTO_CC_OPT} %{MARCH_CC_OPT} %{AUTOFDO_CC_OPT}" \
    --with-ld-opt="%{WITH_LD_OPT} %{CRYPTO_LD_OPT} %{LTO_LD_OPT} %{LINKER_LD_OPT}" \
    --with-debug
%{CRYPTO_POST_CONFIGURE}
make %{?_smp_mflags}
%{__mv} %{bdir}/objs/nginx \
    %{bdir}/objs/nginx-debug
./configure %{BASE_CONFIGURE_ARGS} %{ZLIB_CONFIGURE_ARGS} %{CRYPTO_CONFIGURE_ARGS} \
    --with-cc-opt="%{WITH_CC_OPT} %{CRYPTO_CC_OPT} %{LTO_CC_OPT} %{MARCH_CC_OPT} %{AUTOFDO_CC_OPT}" \
    --with-ld-opt="%{WITH_LD_OPT} %{CRYPTO_LD_OPT} %{LTO_LD_OPT} %{LINKER_LD_OPT}"
%{CRYPTO_POST_CONFIGURE}
make %{?_smp_mflags}

%install
%{__rm} -rf $RPM_BUILD_ROOT
%{__make} DESTDIR=$RPM_BUILD_ROOT INSTALLDIRS=vendor install

# With --prefix=/usr/local/nginx, make install puts html at cm_htmldir already
# No need to move html — it's already at %{cm_htmldir}

# Remove .default config files and fastcgi.conf installed by make install
%{__rm} -f $RPM_BUILD_ROOT%{cm_confdir}/*.default
%{__rm} -f $RPM_BUILD_ROOT%{cm_confdir}/fastcgi.conf

# Create cache directory (temp paths are under here)
%{__mkdir} -p $RPM_BUILD_ROOT%{cm_cachedir}

# Create modules directory (no symlink needed — modules-path is already under prefix)
%{__mkdir} -p $RPM_BUILD_ROOT%{cm_moduledir}

# Install documentation
%{__mkdir} -p $RPM_BUILD_ROOT%{_datadir}/doc/%{name}-%{base_version}
%{__install} -m 644 -p %{SOURCE8} \
    $RPM_BUILD_ROOT%{_datadir}/doc/%{name}-%{base_version}/COPYRIGHT

# Install custom nginx.conf and default server config
%{__mkdir} -p $RPM_BUILD_ROOT%{cm_confdir}/conf.d
%{__rm} $RPM_BUILD_ROOT%{cm_confdir}/nginx.conf
%{__install} -m 644 -p %{SOURCE2} \
    $RPM_BUILD_ROOT%{cm_confdir}/nginx.conf
%{__install} -m 644 -p %{SOURCE3} \
    $RPM_BUILD_ROOT%{cm_confdir}/conf.d/default.conf

# Create dynamic-modules.d/ directory for per-module drop-in configs
%{__mkdir} -p $RPM_BUILD_ROOT%{cm_confdir}/dynamic-modules.d

# Install dynamic module loading config files
%{__install} -m 644 -p %{SOURCE10} \
    $RPM_BUILD_ROOT%{cm_confdir}/dynamic-modules.conf
%{__install} -m 644 -p %{SOURCE11} \
    $RPM_BUILD_ROOT%{cm_confdir}/dynamic-modules-includes.conf

# Install Centmin Mod config include files (Tier 1 — always safe)
%{__install} -m 644 -p %{SOURCE12} \
    $RPM_BUILD_ROOT%{cm_confdir}/maintenance.conf
%{__install} -m 644 -p %{SOURCE13} \
    $RPM_BUILD_ROOT%{cm_confdir}/sitestatus.conf
%{__install} -m 644 -p %{SOURCE14} \
    $RPM_BUILD_ROOT%{cm_confdir}/webp.conf
%{__install} -m 644 -p %{SOURCE15} \
    $RPM_BUILD_ROOT%{cm_confdir}/ssl_include.conf
%{__install} -m 644 -p %{SOURCE16} \
    $RPM_BUILD_ROOT%{cm_confdir}/fastcgi_param_https_map.conf
%{__install} -m 644 -p %{SOURCE17} \
    $RPM_BUILD_ROOT%{cm_confdir}/normalize_encoding.conf
%{__install} -m 644 -p %{SOURCE18} \
    $RPM_BUILD_ROOT%{cm_confdir}/default_phpupstream.conf

# Install module-dependent config files (Tier 2 — commented in nginx.conf)
%{__install} -m 644 -p %{SOURCE19} \
    $RPM_BUILD_ROOT%{cm_confdir}/vts_http.conf
%{__install} -m 644 -p %{SOURCE20} \
    $RPM_BUILD_ROOT%{cm_confdir}/vts_server.conf
%{__install} -m 644 -p %{SOURCE21} \
    $RPM_BUILD_ROOT%{cm_confdir}/vts_mainserver.conf
%{__install} -m 644 -p %{SOURCE22} \
    $RPM_BUILD_ROOT%{cm_confdir}/geoip.conf
%{__install} -m 644 -p %{SOURCE23} \
    $RPM_BUILD_ROOT%{cm_confdir}/pagespeedadmin.conf

# Install vhost include files (Tier 3)
%{__install} -m 644 -p %{SOURCE24} \
    $RPM_BUILD_ROOT%{cm_confdir}/drop.conf
%{__install} -m 644 -p %{SOURCE25} \
    $RPM_BUILD_ROOT%{cm_confdir}/staticfiles.conf
%{__install} -m 644 -p %{SOURCE26} \
    $RPM_BUILD_ROOT%{cm_confdir}/php.conf
%{__install} -m 644 -p %{SOURCE27} \
    $RPM_BUILD_ROOT%{cm_confdir}/errorpage.conf
%{__install} -m 644 -p %{SOURCE28} \
    $RPM_BUILD_ROOT%{cm_confdir}/phpstatus.conf

# Create additional directories
%{__mkdir} -p $RPM_BUILD_ROOT%{cm_confdir}/ssl
%{__mkdir} -p $RPM_BUILD_ROOT/var/log/nginx

# Install man pages (system location)
%{__install} -p -D -m 0644 %{bdir}/objs/nginx.8 \
    $RPM_BUILD_ROOT%{_mandir}/man8/nginx.8

# Install systemd service files (system location)
%{__mkdir} -p $RPM_BUILD_ROOT%{_unitdir}
%{__install} -m644 %SOURCE4 \
    $RPM_BUILD_ROOT%{_unitdir}/nginx.service
%{__install} -m644 %SOURCE7 \
    $RPM_BUILD_ROOT%{_unitdir}/nginx-debug.service
%{__mkdir} -p $RPM_BUILD_ROOT%{_libexecdir}/initscripts/legacy-actions/nginx
%{__install} -m755 %SOURCE5 \
    $RPM_BUILD_ROOT%{_libexecdir}/initscripts/legacy-actions/nginx/upgrade
%{__install} -m755 %SOURCE9 \
    $RPM_BUILD_ROOT%{_libexecdir}/initscripts/legacy-actions/nginx/check-reload

# Install logrotate configuration (system location, EL only — no SUSE)
%{__mkdir} -p $RPM_BUILD_ROOT%{_sysconfdir}/logrotate.d
%{__install} -m 644 -p %{SOURCE1} \
    $RPM_BUILD_ROOT%{_sysconfdir}/logrotate.d/nginx

# Install debug binary
%{__install} -m755 %{bdir}/objs/nginx-debug \
    $RPM_BUILD_ROOT%{cm_sbindir}/nginx-debug

# Remove charset conversion files (not needed by Centmin Mod)
%{__rm} -f $RPM_BUILD_ROOT%{cm_confdir}/koi-utf
%{__rm} -f $RPM_BUILD_ROOT%{cm_confdir}/koi-win
%{__rm} -f $RPM_BUILD_ROOT%{cm_confdir}/win-utf

%check
%{__rm} -rf $RPM_BUILD_ROOT/usr/src
cd %{bdir}
grep -v 'usr/src' debugfiles.list > debugfiles.list.new && mv debugfiles.list.new debugfiles.list
cat /dev/null > debugsources.list

%clean
%{__rm} -rf $RPM_BUILD_ROOT

%files
%defattr(-,root,root)

%{cm_sbindir}/nginx
%{cm_sbindir}/nginx-debug

%dir %{cm_prefix}
%dir %{cm_confdir}
%dir %{cm_confdir}/conf.d
%dir %{cm_confdir}/ssl
%dir %{cm_confdir}/dynamic-modules.d
%dir %{cm_moduledir}
%dir %{cm_logdir}
%dir /var/log/nginx

%config(noreplace) %{cm_confdir}/nginx.conf
%config(noreplace) %{cm_confdir}/conf.d/default.conf
%config(noreplace) %{cm_confdir}/mime.types
%config(noreplace) %{cm_confdir}/fastcgi_params
%config(noreplace) %{cm_confdir}/scgi_params
%config(noreplace) %{cm_confdir}/uwsgi_params

# Dynamic module loading (base RPM owned, not noreplace)
%{cm_confdir}/dynamic-modules.conf
%config(noreplace) %{cm_confdir}/dynamic-modules-includes.conf

# Centmin Mod config include files (Tier 1 — always safe)
%config(noreplace) %{cm_confdir}/maintenance.conf
%config(noreplace) %{cm_confdir}/sitestatus.conf
%config(noreplace) %{cm_confdir}/webp.conf
%config(noreplace) %{cm_confdir}/ssl_include.conf
%config(noreplace) %{cm_confdir}/fastcgi_param_https_map.conf
%config(noreplace) %{cm_confdir}/normalize_encoding.conf
%config(noreplace) %{cm_confdir}/default_phpupstream.conf

# Module-dependent config files (Tier 2 — commented in nginx.conf)
%config(noreplace) %{cm_confdir}/vts_http.conf
%config(noreplace) %{cm_confdir}/vts_server.conf
%config(noreplace) %{cm_confdir}/vts_mainserver.conf
%config(noreplace) %{cm_confdir}/geoip.conf
%config(noreplace) %{cm_confdir}/pagespeedadmin.conf

# Vhost include files (Tier 3)
%config(noreplace) %{cm_confdir}/drop.conf
%config(noreplace) %{cm_confdir}/staticfiles.conf
%config(noreplace) %{cm_confdir}/php.conf
%config(noreplace) %{cm_confdir}/errorpage.conf
%config(noreplace) %{cm_confdir}/phpstatus.conf

%config(noreplace) %{_sysconfdir}/logrotate.d/nginx
%{_unitdir}/nginx.service
%{_unitdir}/nginx-debug.service
%dir %{_libexecdir}/initscripts/legacy-actions/nginx
%{_libexecdir}/initscripts/legacy-actions/nginx/*

%dir %{cm_htmldir}
%{cm_htmldir}/*

%attr(0755,root,root) %dir %{cm_cachedir}

%dir %{_datadir}/doc/%{name}-%{base_version}
%doc %{_datadir}/doc/%{name}-%{base_version}/COPYRIGHT
%{_mandir}/man8/nginx.8*

%pre
# Add the "nginx" user
getent group %{nginx_group} >/dev/null || groupadd -r %{nginx_group}
getent passwd %{nginx_user} >/dev/null || \
    useradd -r -g %{nginx_group} -s /sbin/nologin \
    -d %{nginx_home} -c "nginx user"  %{nginx_user}
exit 0

%post
# Register the nginx service
if [ $1 -eq 1 ]; then
    /usr/bin/systemctl preset nginx.service >/dev/null 2>&1 ||:
    /usr/bin/systemctl preset nginx-debug.service >/dev/null 2>&1 ||:
    # print site info
    cat <<BANNER
----------------------------------------------------------------------

Thanks for using Centmin Mod nginx!

Documentation: https://centminmod.com/
Nginx docs:    https://nginx.org/en/docs/

Config:  %{cm_confdir}/nginx.conf
Binary:  %{cm_sbindir}/nginx
Modules: %{cm_moduledir}/
Logs:    %{cm_logdir}/

----------------------------------------------------------------------
BANNER

    # Touch and set permissions on default log files on installation

    if [ -d %{cm_logdir} ]; then
        if [ ! -e %{cm_logdir}/access.log ]; then
            touch %{cm_logdir}/access.log
            %{__chmod} 640 %{cm_logdir}/access.log
            %{__chown} nginx:%{nginx_loggroup} %{cm_logdir}/access.log
        fi

        if [ ! -e %{cm_logdir}/error.log ]; then
            touch %{cm_logdir}/error.log
            %{__chmod} 640 %{cm_logdir}/error.log
            %{__chown} nginx:%{nginx_loggroup} %{cm_logdir}/error.log
        fi
    fi

    # Create proxy temp directory
    %{__mkdir} -p /tmp/nginx_proxy
    %{__chown} nginx:%{nginx_group} /tmp/nginx_proxy

    # Set permissions on /var/log/nginx for VTS dump and additional logs
    %{__chown} nginx:%{nginx_loggroup} /var/log/nginx

    # SELinux: restore file contexts for /usr/local paths
    restorecon -R %{cm_prefix} 2>/dev/null || true
    restorecon -R %{cm_sbindir}/nginx* 2>/dev/null || true
fi

%preun
if [ $1 -eq 0 ]; then
    /usr/bin/systemctl --no-reload disable nginx.service >/dev/null 2>&1 ||:
    /usr/bin/systemctl stop nginx.service >/dev/null 2>&1 ||:
fi

%postun
/usr/bin/systemctl daemon-reload >/dev/null 2>&1 ||:
if [ $1 -ge 1 ]; then
    /sbin/service nginx status  >/dev/null 2>&1 || exit 0
    /sbin/service nginx upgrade >/dev/null 2>&1 || echo \
        "Binary upgrade failed, please check nginx's error.log"
fi

%changelog
